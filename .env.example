# OCR.space free API key - get yours at https://ocr.space/ocrapi/freekey
OCR_SPACE_API_KEY=your-ocr-space-key-here

# OpenRouter API key - get yours at https://openrouter.ai/keys
# Optional: pipeline works with ocr.space alone
OPENROUTER_API_KEY=your-openrouter-key-here

# Extractor for structured output from LLM responses
# Server port (default: 8000)
PORT=8000

# Extraction mode: hybrid (vision → LLM → regex) | vision-only | llm-only | regex
EXTRACTION_MODE=hybrid

# OpenRouter model IDs (only used in hybrid/vision/llm modes)
VISION_MODEL=google/gemini-2.0-flash-001
TEXT_LLM_MODEL=qwen/qwen3-coder:free
